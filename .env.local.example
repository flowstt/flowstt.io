# Copy this file to .env.local to test platform-specific download button URLs locally.
# .env.local is gitignored and loaded automatically by Vite during `pnpm dev` and `pnpm build`.
#
# Set this to any published release tag to inject direct installer URLs into the build.
# When unset, download buttons fall back to https://github.com/flowstt/flowstt/releases/latest
#
VITE_DOWNLOAD_TAG=v0.1.15
